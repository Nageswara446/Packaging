
def JenkinsEnv = "${env.Build_URL.split('-')[1] == 'prod'  ? 'Prod' : env.Build_URL.split('-')[1] == 'preprod'  ? 'Dev' : 'none' }"
def Ansible = "${env.Build_URL.split('-')[1] == 'prod'  ? 'Ansible Tower Prod' : env.Build_URL.split('-')[1] == 'preprod'  ? 'Ansible Tower ' : 'none' }"

//def agentName = "TerraformAgentAzure${JenkinsEnv == 'Prod' ? LocationToBuild.toLowerCase() : JenkinsEnv == 'Dev' ? 'dgwc1' : 'none'}"

def agentName = "TerraformAgentAzurease1"

pipeline {
    agent {
        label "${agentName}"
    }

    environment {     
        JenkinsEnvVar = "${JenkinsEnv}"
        VDI_BUILD_LOCATION_CE1 = "CE1" // Define the missing property
    }
    stages {
        stage("Read Config"){
            steps {
                dir("configs") {
                    script {
                        def imagesettings = readJSON file: "${VDI_BUILD_LOCATION_CE1}-STD.json"
                        // Update the environment variable
                        env.TenantId = "${imagesettings.tenantId}"
                        env.ARM_SUBSCRIPTION_ID = "${imagesettings.packaging_subscriptionid}"
                        env.Azure_Credential_ID = "${imagesettings.credential}"
                        env.Proxy = "${agentName == 'TerraformAgentAzurease1' ? 'http://proxy-cloudavcinfra-p.gwc1.azure.aztec.cloud.allianz:80' : agentName == 'TerraformAgentAzurease1' ? 'http://proxy-cloudavcinfra-p.fc1.azure.aztec.cloud.allianz:80' : 'http://proxy-cloudavcinfra-p.gwc1.azure.aztec.cloud.allianz:80'}"
                        env.MainVar = "STD.Azure"
                        env.snapshot_ResourceGroup_Name = "${imagesettings.snapshot_ResourceGroup_Name}"
                    }
                }
            }
        }
        stage('Notify/Decommission VM from Azure') {
            steps {
                script {
                    withCredentials([
                        azureServicePrincipal(
                            credentialsId: "${env.Azure_Credential_ID}", 
                            clientIdVariable: 'ARM_CLIENT_ID', 
                            clientSecretVariable: 'ARM_CLIENT_SECRET', 
                            tenantIdVariable: 'ARM_TENANT_ID'
                        ),
                        usernamePassword(credentialsId: 'ebfe6e62-ce6b-4472-8e36-a654bf559bdf', usernameVariable: 'TF_VAR_TMU_username', passwordVariable: 'TF_VAR_TMU_password')
                    ]) {
                        dir("Powershell") {
                            powershell '''
                            
                            # Notify/Decommission VM from Azure
                            ./DecommSnapshot.ps1 -tenantId ${env:ARM_TENANT_ID} -subscriptionId ${env:ARM_SUBSCRIPTION_ID} -clientId ${env:ARM_CLIENT_ID} -clientSecret ${env:ARM_CLIENT_SECRET} -SnapshotResourceGroup ${env:snapshot_ResourceGroup_Name} -TMUusername ${env:TF_VAR_TMU_username} -TMUpassword ${env:TF_VAR_TMU_password}
                           '''
                        }
                    }
                }
            }
        }
    }
    post {
        always {
            script {
                // Check the build result
                if (currentBuild.result == 'FAILURE') {
                    // Send failure notification to the developer's email address
                    emailext subject: "Build #${currentBuild.number}_Test Machine Decommision Job - Failed",
                        body: """Hi Team,

    The packaging VM Decommission job has failed, requiring your immediate attention. Kindly investigate the issue and take the necessary corrective measures.

    Regards,
    Automation Team
    """,
                        to: "extern.b-m_nitin@allianz.de, extern.sakeeth_nudurupati-sai@allianz.de",
                        from: "jenkins@allianz.de"
                }
            }
        }
    }
}
